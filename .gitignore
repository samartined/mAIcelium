# Plugged projects (symlinks to external repos)
/projects/*
!/projects/.gitkeep

# Local registry (contains user-specific paths)
/repos/_registry.yaml
!/repos/_registry.yaml.example

# Auto-generated IDE symlinks (recreated by sync_symlinks.sh)
.cursor/
.agents/
.mcp.json

# Dynamic workspace state
WORKSPACE.md
*.code-workspace
.claude/projects-context.md
.claude/settings.local.json

# IDE caches
.DS_Store
__pycache__/
*.pyc
.env

# Image backups (pre-rename originals)
docs/assets/backup/

# Generated git alias (contains local paths)
bin/.git-alias.sh

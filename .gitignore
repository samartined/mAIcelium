# Plugged projects (symlinks to external repos)
/projects/*
!/projects/.gitkeep

# Mesh layers (standalone git repos or symlinks living inside mesh/layers/)
# Each layer is its own repo or external symlink — not tracked by the workspace repo
/mesh/layers/*
!/mesh/layers/.gitkeep

# MCP source (external pluggable repo — symlink created by bin/add_mcp_source.sh)
/mesh/mcp

# Materialized layer content (symlinks created by sync_symlinks.sh)
# These reflect layer content into the mesh structure for file explorer visibility
/mesh/skills/_common/*
!/mesh/skills/_common/.gitkeep
/mesh/skills/_domains/*
!/mesh/skills/_domains/.gitkeep
/mesh/skills/_clients/*
!/mesh/skills/_clients/.gitkeep
/mesh/rules/_domains/*
!/mesh/rules/_domains/.gitkeep
/mesh/rules/_clients/*
!/mesh/rules/_clients/.gitkeep

# Local registry (contains user-specific paths)
/repos/_registry.yaml
!/repos/_registry.yaml.example

# Auto-generated IDE symlinks (recreated by sync_symlinks.sh)
.cursor/
.agents/
.mcp.json

# Dynamic workspace state
WORKSPACE.md
*.code-workspace
.claude/projects-context.md
.claude/settings.local.json

# IDE caches
.DS_Store
__pycache__/
*.pyc
.env

# Image backups (pre-rename originals)
docs/assets/backup/

# Generated git alias (contains local paths)
bin/.git-alias.sh
